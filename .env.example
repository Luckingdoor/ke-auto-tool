# 贝壳工作台自动化查询工具 - 环境变量配置
# 复制此文件为 .env 并填入实际值

# Cookie 配置（可选：文件路径或直接填写）
# 方式1: 文件路径，指向包含 cookie 字符串的文本文件
COOKIE_FILE=cookie.txt
# 方式2: 直接填写（优先级高于 COOKIE_FILE）
COOKIE_JSON={"name":"supplier_ke_token","value":"...","domain":".ke.com","path":"/"}

# 目标城市（可选，不填则使用 Cookie 默认城市）
# 支持: 北京市, 广州市, 杭州市, 南京市, 武汉市, 西安市
CITY=

# 浏览器模式
# true = 无头模式（后台运行）, false = 显示浏览器窗口（调试用）
HEADLESS=false

# 查询间隔（秒），避免请求过频
QUERY_INTERVAL=2
